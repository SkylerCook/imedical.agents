#!/bin/sh
set -eu

HOOK_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
AGENTS_ROOT=$(CDPATH= cd -- "$HOOK_DIR/.." && pwd)
CHECK_SCRIPT="$AGENTS_ROOT/scripts/check-functional-diff.ps1"

if command -v pwsh >/dev/null 2>&1; then
  POWERSHELL_BIN="pwsh"
else
  POWERSHELL_BIN="powershell.exe"
fi

exec "$POWERSHELL_BIN" -NoProfile -ExecutionPolicy Bypass -File "$CHECK_SCRIPT" -ProjectRoot "." -Staged
